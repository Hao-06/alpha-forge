# GMI Cloud Inference Engine
# 注册 / 获取 Key: https://console.gmicloud.ai
GMI_API_KEY=sk-your-gmi-key-here
GMI_BASE_URL=https://api.gmi-serving.com/v1

# 模型选择（GMI 上的 model id）
# ⚠️ 这些 id 必须与 GMI 控制台 Model Hub 里完全一致，否则 API 会报 400
# 在 https://console.gmicloud.ai 左侧 Model Hub 复制具体 id
MODEL_REGIME=deepseek-ai/DeepSeek-R1-0528
MODEL_STRATEGY=anthropic/claude-opus-4.6
MODEL_RISK=openai/gpt-4o-mini

# CCXT 行情源（无需 API key 也能拿公开数据）
EXCHANGE=binance
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
